# NY Tax Rates (Simplified for Demo)
# In a real app, this would be a large database or an API call to NY Dept of Tax
# Format: County, StateRate, CountyRate, CityRate, SpecialRate (MCTD)

NY_STATE_RATE=0.04
MCTD_RATE=0.00375

# Example counties in MCTD: New York (Manhattan), Bronx, Kings (Brooklyn), Queens, Richmond (Staten Island), Rockland, Nassau, Suffolk, Orange, Putnam, Dutchess, Westchester.

# Frontend deploy base path:
# - "/" for root domain deploys
# - "/2-3unemployed/" for GitHub Pages under repository path
VITE_BASE_PATH=/

# Backend public URL for frontend API calls.
# Example: https://hackathon-api.onrender.com
# Leave empty for local same-origin development.
VITE_API_URL=
